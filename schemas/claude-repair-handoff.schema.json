{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baijin.local/schemas/claude-repair-handoff.schema.json",
  "title": "Baijin Claude Repair Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "handoff_id",
    "source_review_result_id",
    "invocation_id",
    "repository",
    "branch",
    "reviewed_commit",
    "review_commit",
    "verdict",
    "findings",
    "repair_round",
    "max_repair_round",
    "target_actor",
    "forbidden_actions",
    "created_at"
  ],
  "properties": {
    "protocol": {
      "const": "baijin-claude-repair-handoff/1.0"
    },
    "handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "source_review_result_id": {
      "type": "string",
      "minLength": 1
    },
    "invocation_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "enum": [
        "shunhang776/xinbaijin",
        "shunhang776/xinbaijin-mcp"
      ]
    },
    "branch": {
      "const": "dev"
    },
    "reviewed_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "review_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "verdict": {
      "const": "changes_requested"
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "file",
          "line",
          "title",
          "description",
          "recommendation"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "repair_round": {
      "type": "integer",
      "minimum": 0
    },
    "max_repair_round": {
      "type": "integer",
      "minimum": 1
    },
    "target_actor": {
      "const": "claude-code"
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
