{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baijin.local/schemas/claude-repair-submission.schema.json",
  "title": "Baijin Claude Repair Submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "submission_id",
    "source_handoff_id",
    "source_review_result_id",
    "invocation_id",
    "repository",
    "branch",
    "reviewed_commit",
    "review_commit",
    "repair_base_commit",
    "repair_commit",
    "repair_round",
    "max_repair_round",
    "status",
    "actor",
    "fix_summary",
    "changed_files",
    "resolved_findings",
    "forbidden_actions_observed",
    "created_at"
  ],
  "properties": {
    "protocol": {
      "const": "baijin-claude-repair-submission/1.0"
    },
    "submission_id": {
      "type": "string",
      "minLength": 1
    },
    "source_handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "source_review_result_id": {
      "type": "string",
      "minLength": 1
    },
    "invocation_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "enum": [
        "shunhang776/xinbaijin",
        "shunhang776/xinbaijin-mcp"
      ]
    },
    "branch": {
      "const": "dev"
    },
    "reviewed_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "review_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "repair_base_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "repair_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "repair_round": {
      "type": "integer",
      "minimum": 0
    },
    "max_repair_round": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "const": "repair_submitted"
    },
    "actor": {
      "const": "claude-code"
    },
    "fix_summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resolved_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "file",
          "line",
          "title",
          "resolution"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "resolution": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "forbidden_actions_observed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
