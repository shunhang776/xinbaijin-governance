{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baijin.local/schemas/phase5-rollback-plan.schema.json",
  "title": "Baijin Phase5 Rollback Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "rollback_plan_id",
    "phase",
    "repository",
    "branch",
    "mode",
    "rollback_ready",
    "rollback_scope",
    "rollback_triggers",
    "rollback_steps",
    "verification_checks",
    "owners",
    "approvals",
    "source_documents",
    "created_at"
  ],
  "properties": {
    "protocol": {
      "const": "baijin-phase5-rollback-plan/1.0"
    },
    "rollback_plan_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "const": "phase5"
    },
    "repository": {
      "type": "string",
      "enum": [
        "shunhang776/xinbaijin",
        "shunhang776/xinbaijin-mcp"
      ]
    },
    "branch": {
      "const": "dev"
    },
    "mode": {
      "type": "string",
      "enum": [
        "draft",
        "manual_ready"
      ]
    },
    "rollback_ready": {
      "type": "boolean"
    },
    "rollback_scope": {
      "type": "string",
      "enum": [
        "phase5_enablement",
        "gate_production_decision",
        "l4_pipeline",
        "full_l4_loop"
      ]
    },
    "rollback_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "production_gate_misfire",
          "unexpected_auto_merge",
          "wrong_review_commit",
          "stale_review_bypassed",
          "branch_head_guard_bypassed",
          "repair_guard_bypassed",
          "manual_required_not_respected",
          "artifact_integrity_failure",
          "workflow_permission_violation",
          "operator_requested"
        ]
      }
    },
    "rollback_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "action",
          "owner",
          "requires_manual_confirmation"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "requires_manual_confirmation": {
            "type": "boolean"
          }
        }
      }
    },
    "verification_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "expected"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "expected": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_owner",
        "gate_owner",
        "repository_owner"
      ],
      "properties": {
        "rollback_owner": {
          "type": "string",
          "minLength": 1
        },
        "gate_owner": {
          "type": "string",
          "minLength": 1
        },
        "repository_owner": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approvals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_owner_approved",
        "gate_owner_approved",
        "repository_owner_approved"
      ],
      "properties": {
        "rollback_owner_approved": {
          "type": "boolean"
        },
        "gate_owner_approved": {
          "type": "boolean"
        },
        "repository_owner_approved": {
          "type": "boolean"
        }
      }
    },
    "source_documents": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase5_enablement",
        "l4_production_acceptance",
        "gate_enablement_boundary"
      ],
      "properties": {
        "phase5_enablement": {
          "type": "string",
          "minLength": 1
        },
        "l4_production_acceptance": {
          "type": "string",
          "minLength": 1
        },
        "gate_enablement_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "rollback_ready": {
            "const": true
          }
        },
        "required": [
          "rollback_ready"
        ]
      },
      "then": {
        "properties": {
          "mode": {
            "const": "manual_ready"
          },
          "approvals": {
            "properties": {
              "rollback_owner_approved": {
                "const": true
              },
              "gate_owner_approved": {
                "const": true
              },
              "repository_owner_approved": {
                "const": true
              }
            }
          }
        }
      }
    }
  ]
}
