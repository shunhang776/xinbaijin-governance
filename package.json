{
  "name": "xinbaijin-governance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "白槿唯一契约、政策和治理夹具。",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:schema": "node scripts/validate-fixtures.mjs",
    "tools:install": "bash scripts/install-policy-tools.sh",
    "test:policy": "bash scripts/test-policy.sh",
    "test:local": "npm run test:schema && npm test && npm run mutation && npm audit --audit-level=moderate",
    "test:ci": "npm run test:local && npm run test:policy",
    "mutation": "stryker run"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "fast-check": "4.8.0",
    "vitest": "4.1.9"
  },
  "overrides": {
    "qs": "6.15.2"
  }
}
